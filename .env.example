# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your own values. `.env` is gitignored.
# TESTNET ONLY. Never put a mainnet mnemonic or real funds here.
# ---------------------------------------------------------------------------

# BIP-39 mnemonic used to deterministically derive all wallets (path m/44'/60'/0'/0/i).
# Generate a fresh TEST mnemonic, e.g. in a Node REPL:
#   node -e "console.log(require('ethers').Wallet.createRandom().mnemonic.phrase)"
MNEMONIC="test test test test test test test test test test test junk"

# Sepolia RPC endpoint. Primary: Alchemy.
RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"
# Public fallback (may rate-limit under frequent polling):
# RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# Number of wallets to derive. Valid range: 1..20 inclusive.
WALLET_COUNT=3

# Balance polling interval in milliseconds (default 60000 = 60s).
POLL_INTERVAL_MS=60000

# HTTP port for the API.
PORT=3000
